<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.1">
    <persistence-unit name="CollaborationServicePU" transaction-type="JTA">
        <jta-data-source>java:jboss/datasources/CollaborationServiceDS</jta-data-source>
        <class>com.puj.collaboration.entity.Forum</class>
        <class>com.puj.collaboration.entity.Thread</class>
        <class>com.puj.collaboration.entity.Post</class>
        <class>com.puj.collaboration.entity.StudyGroup</class>
        <class>com.puj.collaboration.entity.GroupMember</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="update"/>
            <property name="hibernate.dialect"        value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.default_schema" value="collaboration"/>
            <property name="hibernate.show_sql"       value="false"/>
        </properties>
    </persistence-unit>
</persistence>
