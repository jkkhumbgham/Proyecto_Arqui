<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <persistence-unit name="UserServicePU" transaction-type="JTA">
        <jta-data-source>java:jboss/datasources/UserServiceDS</jta-data-source>

        <class>com.puj.users.entity.User</class>
        <class>com.puj.users.entity.RefreshToken</class>
        <class>com.puj.users.entity.AuditLog</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="update"/>
            <property name="hibernate.dialect"          value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.show_sql"         value="false"/>
            <property name="hibernate.format_sql"       value="false"/>
            <property name="hibernate.default_schema"   value="users"/>
            <property name="hibernate.jdbc.batch_size"  value="25"/>
            <property name="hibernate.order_inserts"    value="true"/>
            <property name="hibernate.order_updates"    value="true"/>
        </properties>
    </persistence-unit>
</persistence>
