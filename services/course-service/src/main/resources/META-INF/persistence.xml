<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.1">
    <persistence-unit name="CourseServicePU" transaction-type="JTA">
        <jta-data-source>java:jboss/datasources/CourseServiceDS</jta-data-source>
        <class>com.puj.courses.entity.Course</class>
        <class>com.puj.courses.entity.Module</class>
        <class>com.puj.courses.entity.Lesson</class>
        <class>com.puj.courses.entity.Enrollment</class>
        <class>com.puj.courses.entity.S3Resource</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="update"/>
            <property name="hibernate.dialect"        value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.default_schema" value="courses"/>
            <property name="hibernate.show_sql"       value="false"/>
            <property name="hibernate.jdbc.batch_size" value="25"/>
        </properties>
    </persistence-unit>
</persistence>
