{
  "vhosts": [{ "name": "puj_vhost" }],
  "exchanges": [
    {
      "name": "platform.events",
      "vhost": "puj_vhost",
      "type": "topic",
      "durable": true,
      "auto_delete": false
    },
    {
      "name": "platform.dlx",
      "vhost": "puj_vhost",
      "type": "fanout",
      "durable": true,
      "auto_delete": false
    }
  ],
  "queues": [
    {
      "name": "analytics.results",
      "vhost": "puj_vhost",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "platform.dlx",
        "x-message-ttl": 86400000
      }
    },
    {
      "name": "email.notifications",
      "vhost": "puj_vhost",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "platform.dlx",
        "x-message-ttl": 86400000
      }
    },
    {
      "name": "dead.letter.queue",
      "vhost": "puj_vhost",
      "durable": true,
      "auto_delete": false
    }
  ],
  "bindings": [
    {
      "source": "platform.events",
      "vhost": "puj_vhost",
      "destination": "analytics.results",
      "destination_type": "queue",
      "routing_key": "analytics.#"
    },
    {
      "source": "platform.events",
      "vhost": "puj_vhost",
      "destination": "email.notifications",
      "destination_type": "queue",
      "routing_key": "email.#"
    },
    {
      "source": "platform.dlx",
      "vhost": "puj_vhost",
      "destination": "dead.letter.queue",
      "destination_type": "queue",
      "routing_key": "#"
    }
  ]
}
