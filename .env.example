# ─── Copia este archivo como .env y ejecuta: bash scripts/setup-env.sh ──────
# .env nunca se sube a git (está en .gitignore)

# ── JWT (generado automáticamente por setup-env.sh) ──────────────────────────
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── AWS (rellena a mano una sola vez) ────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Registry de imágenes Docker ──────────────────────────────────────────────
# Ejemplo ECR:  123456789.dkr.ecr.us-east-1.amazonaws.com
# Ejemplo local: localhost:5000
REGISTRY=

# ── SMTP (solo para producción; en local usa MailHog automáticamente) ─────────
SMTP_HOST=smtp.puj.edu.co
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_ENABLED=true
